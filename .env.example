# Volatility Prediction System - Environment Variables
# Copy this file to .env and customize as needed

# Data Configuration
TICKER=AAPL
START_DATE=2019-01-01
END_DATE=2024-12-31

# Model Configuration
TRAIN_WINDOW_YEARS=3
TEST_WINDOW_YEARS=1
STEP_SIZE_YEARS=1

# Trading Configuration
ACCOUNT_SIZE=100000
MAX_DRAWDOWN_LIMIT=0.20
BID_ASK_SPREAD_PCT=0.001
SLIPPAGE_PCT=0.0005
COMMISSION_PER_TRADE=0
POSITION_SIZE_METHOD=kelly
FIXED_POSITION_PCT=0.02
MIN_SIGNAL_STRENGTH=0.55
VOL_PREMIUM_MULTIPLIER=1.0

# Logging
LOG_LEVEL=INFO
RESULTS_DIR=./results

# Optional licensed historical-options providers
# OPTIONS_PROVIDER=alpha_vantage
# ALPHAVANTAGE_API_KEY=
# POLYGON_API_KEY=
# ORATS_API_KEY=
